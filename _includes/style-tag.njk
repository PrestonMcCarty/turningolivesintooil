<style>

  :root{
    --olive:#6B7A46;
    --olive-deep:#4C5936;
    --sage:#A8B89A;
    --cream:#F8F4EC;
    --taupe:#C9B8A6;
    --gold:#C89C3D;
    --ink:#3B3A33;
    --serif: 'Cormorant Garamond', serif;
    --sans: 'Lato', sans-serif;
  }
  *{box-sizing:border-box; margin:0; padding:0;}
  html{scroll-behavior:smooth;}
  body{
    background:var(--cream);
    color:var(--ink);
    font-family:var(--sans);
    font-weight:300;
    line-height:1.7;
    -webkit-font-smoothing:antialiased;
  }
  a{color:inherit; text-decoration:none;}
  img{max-width:100%; display:block;}
  .wrap{max-width:1180px; margin:0 auto; padding:0 32px;}
  h1,h2,h3,h4{font-family:var(--serif); font-weight:500; letter-spacing:.01em; color:var(--olive-deep);}
  .eyebrow{
    font-family:var(--sans); font-size:12.5px; letter-spacing:.22em; text-transform:uppercase;
    color:var(--olive); font-weight:700;
  }

  /* ---------- header ---------- */
  header{
    position:sticky; top:0; z-index:50;
    background:rgba(248,244,236,.92);
    backdrop-filter:blur(6px);
    border-bottom:1px solid rgba(107,122,70,.15);
  }
  .nav-inner{
    max-width:1180px; margin:0 auto; padding:18px 32px;
    display:flex; align-items:center; justify-content:space-between;
  }
  .brand{display:flex; align-items:center; gap:10px;}
  .brand svg{width:30px; height:30px; flex-shrink:0;}
  .brand .logo-mark{width:38px; height:38px; flex-shrink:0; object-fit:contain;}
  .brand span{font-family:var(--serif); font-size:22px; color:var(--olive-deep); font-style:italic;}
  nav.links{display:flex; gap:28px; font-size:14px; letter-spacing:.03em;}
  nav.links a{position:relative; padding:4px 0; color:var(--ink); transition:color .2s;}
  nav.links a:hover{color:var(--olive);}
  nav.links a::after{
    content:""; position:absolute; left:0; bottom:0; width:0; height:1px; background:var(--gold);
    transition:width .25s ease;
  }
  nav.links a:hover::after{width:100%;}
  .nav-cta{
    border:1px solid var(--olive); padding:9px 20px; border-radius:2px; font-size:13px; letter-spacing:.05em;
    transition:background .2s, color .2s;
    margin-left:36px;
    flex-shrink:0;
  }
  .nav-cta:hover{background:var(--olive); color:var(--cream);}
  .menu-toggle{
    display:none; flex-direction:column; justify-content:center; gap:5px;
    width:38px; height:38px; padding:7px; background:none; border:none; cursor:pointer;
  }
  .menu-toggle .menu-bar{
    display:block; width:24px; height:2px; margin:0 auto; border-radius:2px;
    background:var(--olive-deep); transition:transform .25s ease, opacity .25s ease;
  }

  /* ---------- mobile slide-out menu ---------- */
  .mobile-menu-overlay{
    position:fixed; inset:0; background:rgba(59,58,51,.45);
    opacity:0; visibility:hidden; transition:opacity .3s ease, visibility .3s ease;
    z-index:60;
  }
  .mobile-menu-overlay.show{opacity:1; visibility:visible;}
  .mobile-menu{
    position:fixed; top:0; right:0; height:100%; width:min(82vw, 330px);
    background:var(--cream); z-index:70;
    transform:translateX(100%); transition:transform .32s ease;
    box-shadow:-8px 0 30px rgba(0,0,0,.14);
    padding:76px 32px 36px; display:flex; flex-direction:column;
  }
  .mobile-menu.open{transform:translateX(0);}
  .mobile-menu-close{
    position:absolute; top:18px; right:22px;
    width:40px; height:40px; background:none; border:none; cursor:pointer;
    font-size:32px; line-height:1; color:var(--olive-deep); font-family:var(--sans);
  }
  .mobile-links{display:flex; flex-direction:column;}
  .mobile-links a{
    font-family:var(--serif); font-size:22px; color:var(--olive-deep);
    padding:13px 2px; border-bottom:1px solid rgba(107,122,70,.14); transition:color .2s;
  }
  .mobile-links a:hover{color:var(--olive);}
  .mobile-cta{
    margin-top:auto; text-align:center; border:1px solid var(--olive); border-radius:2px;
    padding:14px 20px; font-size:13px; letter-spacing:.06em; text-transform:uppercase;
    font-weight:700; color:var(--olive-deep); transition:background .2s, color .2s;
  }
  .mobile-cta:hover{background:var(--olive); color:var(--cream);}

  /* ---------- hero ---------- */
  .hero{
    position:relative; overflow:hidden;
    padding:100px 32px 120px;
    text-align:center;
    background:
      radial-gradient(ellipse at 20% 15%, rgba(168,184,154,.35), transparent 55%),
      radial-gradient(ellipse at 85% 80%, rgba(200,156,61,.14), transparent 50%),
      var(--cream);
  }
  .hero-branch{width:120px; margin:0 auto 28px; opacity:.85;}
  .hero .eyebrow{display:block; margin-bottom:18px;}
  .hero h1{
    font-size:clamp(40px, 6.5vw, 74px);
    max-width:900px; margin:0 auto; line-height:1.08;
  }
  .hero h1 em{font-style:italic; color:var(--gold);}
  .hero p.lede{
    max-width:560px; margin:26px auto 0; font-size:19px; color:#5c5a4d; font-weight:300;
  }
  .hero-actions{
    display:flex; flex-wrap:wrap; gap:14px; justify-content:center; margin-top:42px;
  }
  .btn{
    display:inline-block; padding:14px 30px; font-size:13.5px; letter-spacing:.06em;
    border-radius:2px; font-family:var(--sans); font-weight:700; transition:all .25s ease;
    text-transform:uppercase;
  }
  .btn-solid{background:var(--olive); color:var(--cream);}
  .btn-solid:hover{background:var(--olive-deep);}
  .btn-outline{border:1px solid var(--taupe); color:var(--olive-deep);}
  .btn-outline:hover{border-color:var(--olive); background:rgba(107,122,70,.06);}

  /* ---------- divider ---------- */
  .divider{display:flex; justify-content:center; padding:6px 0;}
  .divider svg{width:180px; height:28px; opacity:.55;}

  /* ---------- mission / pressing metaphor ---------- */
  .mission{padding:90px 32px 100px; text-align:center;}
  .mission .eyebrow{display:block; margin-bottom:16px;}
  .mission h2{font-size:clamp(30px,4vw,42px); max-width:680px; margin:0 auto 22px;}
  .mission p{max-width:640px; margin:0 auto; font-size:17px; color:#5c5a4d;}
  .press-steps{
    display:flex; justify-content:center; gap:0; margin-top:64px; flex-wrap:wrap;
  }
  .press-step{
    width:230px; padding:0 20px; position:relative;
  }
  .press-step svg{width:52px; height:52px; margin:0 auto 18px; color:var(--olive);}
  .press-step h4{font-size:20px; margin-bottom:8px;}
  .press-step p{font-size:14.5px; color:#6b6a5d;}
  .press-arrow{
    display:flex; align-items:center; color:var(--taupe); font-size:22px; padding-top:26px;
  }

  /* ---------- categories ---------- */
  .categories{background:var(--olive-deep); padding:90px 32px;}
  .categories .head{text-align:center; margin-bottom:56px;}
  .categories .eyebrow{color:var(--sage); display:block; margin-bottom:14px;}
  .categories h2{color:var(--cream); font-size:clamp(30px,4vw,42px);}
  .cat-grid{
    display:grid; grid-template-columns:repeat(auto-fit, minmax(210px,1fr)); gap:2px;
    max-width:1180px; margin:0 auto;
  }
  .cat-card{
    background:rgba(248,244,236,.05);
    border:1px solid rgba(248,244,236,.14);
    padding:38px 26px; text-align:center; transition:background .3s;
  }
  .cat-card:hover{background:rgba(248,244,236,.09);}
  .cat-card svg{width:34px; height:34px; margin:0 auto 18px; color:var(--gold);}
  .cat-card h3{color:var(--cream); font-size:22px; margin-bottom:10px; font-weight:500;}
  .cat-card p{color:#D8DCC9; font-size:13.5px; font-family:var(--sans); line-height:1.6;}

  /* ---------- featured ---------- */
  .featured{padding:100px 32px; max-width:1180px; margin:0 auto;}
  .featured .head{text-align:center; margin-bottom:60px;}
  .featured .eyebrow{display:block; margin-bottom:14px;}
  .featured h2{font-size:clamp(30px,4vw,42px);}
  .feat-grid{display:grid; grid-template-columns:repeat(auto-fit,minmax(280px,1fr)); gap:36px;}
  .feat-card{background:#fff; border:1px solid rgba(107,122,70,.12);}
  .feat-img{
    height:200px; display:flex; align-items:center; justify-content:center;
  }
  .feat-img.a{background:linear-gradient(135deg, #8B9A64, #6B7A46);}
  .feat-img.b{background:linear-gradient(135deg, #C9B8A6, #A8917A);}
  .feat-img.c{background:linear-gradient(135deg, #C89C3D, #A87F2C);}
  .feat-img svg{width:44px; height:44px; color:rgba(255,255,255,.85);}
  .feat-body{padding:28px 26px 32px;}
  .feat-tag{font-size:11px; letter-spacing:.14em; text-transform:uppercase; color:var(--olive); font-weight:700; font-family:var(--sans);}
  .feat-body h3{font-size:23px; margin:10px 0 10px;}
  .feat-body p{font-size:14.5px; color:#6b6a5d; margin-bottom:16px;}
  .feat-link{font-size:13px; font-weight:700; letter-spacing:.03em; color:var(--gold); border-bottom:1px solid transparent;}
  .feat-link:hover{border-color:var(--gold);}

  /* ---------- resources ---------- */
  .resources{background:var(--sage); background:linear-gradient(180deg, rgba(168,184,154,.28), rgba(168,184,154,.05)); padding:100px 32px;}
  .res-inner{max-width:1180px; margin:0 auto; display:grid; grid-template-columns:1fr 1fr; gap:70px; align-items:center;}
  .res-inner .eyebrow{display:block; margin-bottom:14px;}
  .res-inner h2{font-size:clamp(28px,3.6vw,38px); margin-bottom:18px;}
  .res-inner p{color:#5c5a4d; font-size:16px; margin-bottom:0;}
  .res-list{list-style:none;}
  .res-list li{
    display:flex; align-items:center; gap:14px; padding:16px 0; border-bottom:1px solid rgba(76,89,54,.15);
    font-family:var(--serif); font-size:19px; color:var(--olive-deep);
  }
  .res-list li:last-child{border-bottom:none;}
  .res-list svg{width:18px; height:18px; color:var(--gold); flex-shrink:0;}

  /* ---------- signup ---------- */
  .signup{padding:110px 32px; text-align:center; position:relative;}
  .signup-branch{width:90px; margin:0 auto 26px; opacity:.8;}
  .signup .eyebrow{display:block; margin-bottom:16px;}
  .signup h2{font-size:clamp(28px,4vw,40px); max-width:600px; margin:0 auto 16px;}
  .signup p{max-width:480px; margin:0 auto 34px; color:#5c5a4d; font-size:16px;}
  .signup-form{display:flex; gap:10px; justify-content:center; flex-wrap:wrap; max-width:440px; margin:0 auto;}
  .signup-form input{
    flex:1; min-width:220px; padding:15px 18px; border:1px solid var(--taupe); background:#fff;
    font-family:var(--sans); font-size:14px; border-radius:2px;
  }
  .signup-form input:focus{outline:2px solid var(--olive); outline-offset:1px;}
  .signup-note{font-size:12px; color:#8a8875; margin-top:16px; letter-spacing:.02em;}

  /* ---------- footer ---------- */
  footer{background:var(--olive-deep); color:#D8DCC9; padding:70px 32px 34px;}
  .foot-inner{
    max-width:1180px; margin:0 auto; display:grid; grid-template-columns:1.4fr 1fr 1fr 1fr; gap:46px;
  }
  .foot-brand .brand span{color:var(--cream);}
  .foot-brand p{font-size:13.5px; margin-top:16px; color:#B9C0AA; max-width:280px;}
  footer h5{
    font-family:var(--sans); font-size:12px; letter-spacing:.14em; text-transform:uppercase;
    color:var(--gold); margin-bottom:18px; font-weight:700;
  }
  footer ul{list-style:none;}
  footer li{margin-bottom:11px; font-size:14px;}
  footer a:hover{color:#fff;}
  .foot-bottom{
    max-width:1180px; margin:56px auto 0; padding-top:26px; border-top:1px solid rgba(248,244,236,.12);
    display:flex; justify-content:space-between; flex-wrap:wrap; gap:12px; font-size:12.5px; color:#9AA687;
  }

  @media (max-width:820px){
    nav.links{display:none;}
    .nav-cta{display:none;}
    .menu-toggle{display:flex;}
    .press-steps{flex-direction:column; align-items:center;}
    .press-arrow{transform:rotate(90deg); padding:8px 0;}
    .res-inner{grid-template-columns:1fr;}
    .foot-inner{grid-template-columns:1fr 1fr;}
  }

  /* ---------- shared inner-page components ---------- */
  .crumb{max-width:1180px; margin:22px auto 0; padding:0 32px; font-size:12.5px; color:#8a8875;}
  .crumb a{color:var(--olive);}
  .crumb a:hover{text-decoration:underline;}

  .page-hero{padding:70px 32px 64px; text-align:center; background:linear-gradient(180deg, rgba(168,184,154,.18), transparent);}
  .page-hero .eyebrow{display:block; margin-bottom:14px;}
  .page-hero h1{font-size:clamp(34px,5vw,54px); max-width:680px; margin:0 auto 18px;}
  .page-hero p{max-width:560px; margin:0 auto; color:#5c5a4d; font-size:17px;}

  .coming-grid{max-width:1180px; margin:0 auto; padding:70px 32px 100px; display:grid; grid-template-columns:repeat(auto-fit,minmax(280px,1fr)); gap:32px;}
  .coming-card{background:#fff; border:1px solid rgba(107,122,70,.12); padding:34px 28px;}
  .coming-badge{display:inline-block; font-size:10.5px; letter-spacing:.12em; text-transform:uppercase; font-weight:700; color:var(--gold); border:1px solid var(--gold); padding:4px 10px; border-radius:2px; margin-bottom:18px;}
  .coming-card h3{font-size:22px; margin-bottom:10px;}
  .coming-card p{font-size:14px; color:#6b6a5d;}

  .about-hero{max-width:1000px; margin:0 auto; padding:80px 32px 30px; display:grid; grid-template-columns:240px 1fr; gap:56px; align-items:center;}
  .about-photo{width:240px; height:240px; border-radius:50%; background:radial-gradient(circle at 30% 30%, #A8B89A, #6B7A46); flex-shrink:0;}
  .about-hero h1{font-size:clamp(30px,4.5vw,44px); margin-bottom:16px;}
  .about-hero p{color:#5c5a4d; font-size:16px;}
  .about-body{max-width:720px; margin:0 auto; padding:20px 32px 40px; color:#5c5a4d; font-size:16px;}
  .about-body p{margin-bottom:20px;}
  .about-values{max-width:1000px; margin:0 auto; padding:40px 32px 100px; display:grid; grid-template-columns:repeat(auto-fit,minmax(230px,1fr)); gap:32px; border-top:1px solid rgba(107,122,70,.15);}
  .about-values .val{padding-top:36px;}
  .about-values .val h4{font-size:20px; margin-bottom:8px;}
  .about-values .val p{font-size:14px; color:#6b6a5d;}

  .resource-grid{max-width:1180px; margin:0 auto; padding:70px 32px 100px; display:grid; grid-template-columns:repeat(auto-fit,minmax(260px,1fr)); gap:30px;}
  .resource-card{background:#fff; border:1px solid rgba(107,122,70,.12); padding:32px 26px; text-align:center;}
  .resource-card svg{width:36px; height:36px; margin:0 auto 16px; color:var(--olive);}
  .resource-card h3{font-size:19px; margin-bottom:10px;}
  .resource-card p{font-size:13.5px; color:#6b6a5d; margin-bottom:20px;}
  .resource-btn{display:inline-block; font-size:11.5px; letter-spacing:.06em; text-transform:uppercase; font-weight:700; border:1px solid var(--taupe); color:#948d7d; padding:10px 18px; border-radius:2px; cursor:not-allowed; background:#faf8f3;}

  .contact-wrap{max-width:620px; margin:0 auto; padding:80px 32px 110px;}
  .contact-wrap h1{text-align:center; font-size:clamp(32px,4.5vw,44px); margin-bottom:16px;}
  .contact-wrap > p.lede{text-align:center; color:#5c5a4d; margin-bottom:44px;}
  .contact-form-full label{display:block; font-size:13px; letter-spacing:.03em; color:var(--olive-deep); margin-bottom:7px; font-weight:700;}
  .contact-form-full input, .contact-form-full textarea{width:100%; padding:13px 16px; border:1px solid var(--taupe); background:#fff; font-family:var(--sans); font-size:14px; border-radius:2px; margin-bottom:22px;}
  .contact-form-full textarea{min-height:140px; resize:vertical;}
  .tip-box{background:rgba(200,156,61,.1); border:1px solid rgba(200,156,61,.3); padding:16px 20px; border-radius:2px; font-size:13px; color:#7a6224; margin-top:8px; line-height:1.6;}

  @media (max-width:700px){
    .about-hero{grid-template-columns:1fr; text-align:center; justify-items:center;}
  }

</style>